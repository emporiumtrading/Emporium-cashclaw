{
  "name": "cashclaw-agent",
  "version": "0.1.0",
  "description": "Autonomous work agent for the moltlaunch marketplace",
  "license": "MIT",
  "author": "Moltlaunch",
  "type": "module",
  "bin": {
    "cashclaw": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:ui": "vite build",
    "build:all": "tsup && vite build",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'test/**/*.ts'"
  },
  "dependencies": {
    "minisearch": "^7.2.0",
    "viem": "^2.23.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
